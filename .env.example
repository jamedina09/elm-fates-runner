# Copy this file to .env and fill in your own values (see README "Configuration").
# .env is gitignored so your local paths never get committed.

# Absolute path to the directory on your machine you want mirrored into the
# container at /projects_mirror (inputdata, scratch, archive, scripts, ...).
PROJECT_DIRECTORY=/absolute/path/to/your/projects

# Which image version to run. "latest" tracks the newest build; pin to a
# specific FATES/API version (see CHANGELOG.md) for reproducibility.
IMAGE_TAG=latest

# Your host user's UID/GID (run `id -u` and `id -g` to get these). The
# container remaps its internal user to match these at startup, so files it
# creates in PROJECT_DIRECTORY are owned by you instead of a container
# default. Get these wrong (or leave them out) and file ownership/permission
# errors show up as soon as you touch files under /projects_mirror.
LOCAL_UID=1000
LOCAL_GID=1000
